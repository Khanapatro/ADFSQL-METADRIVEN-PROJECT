									"name": "ExecuteChild",
									"type": "ExecutePipeline",
									"dependsOn": [
										{
											"activity": "SetFolderName",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"pipeline": {
											"referenceName": "PL_MetaDataChild",
											"type": "PipelineReference"
										},
										"waitOnCompletion": true,
										"parameters": {
											"param_foldername": {
												"value": "@variables('FolderName')",
												"type": "Expression"
											}
										}
									}
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"variables": {
					"FolderName": {
						"type": "String"
					}
				},
				"annotations": [],
				"lastPublishTime": "2026-06-22T06:45:47Z"
			},
			"dependsOn": [
